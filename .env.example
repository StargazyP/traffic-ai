# 이 파일을 복사: cp .env.example .env  후 URL만 채우세요.
# 앱은 프로젝트 루트의 .env 를 자동으로 읽습니다.

# ITS OpenAPI (CCTV 목록·cctvurl). 미설정 시 코드 기본 키(127cdf2b...)가 쓰입니다.
# ITS_API_KEY=발급받은_키

# 테스트: 한 개 m3u8만 있으면 아래 한 줄만 넣어도 5지점 이름으로 로테이션됩니다.
# CCTV_URL=https://openapi.its.go.kr/.../stream.m3u8
#
# 위 변수들을 비우면 서버가 ITS OpenAPI(its_client)로 판교·하남·서창·김포·광명 CCTV URL을 자동 조회합니다.

# 운영: 지점별로 다른 스트림이면 각각 지정 (비어 있으면 CCTV_URL 로 대체됨)
# CCTV_URL_PANGYO=
# CCTV_URL_HANAM=
# CCTV_URL_SEOCHANG=
# CCTV_URL_GIMPO=
# CCTV_URL_GWANGMYEONG=

CCTV_ROTATION_SEC=30

# 가상선 세로 위치 = 프레임 높이 × 이 값 (0.05~0.95로 클램프)
LINE_Y_RATIO=0.6

# 로테이션 YOLO track 신뢰도 하한 (낮출수록 검출↑, 오검출↑)
YOLO_TRACK_CONF=0.25

# 하단 CCTV 미리보기 HLS 프록시(브라우저 403 방지). 필요 시 Referer/Origin 조정.
# HLS_PROXY_REFERER=https://openapi.its.go.kr/
# HLS_PROXY_ORIGIN=https://openapi.its.go.kr
# HLS_PROXY_ALLOWED_HOSTS=cctvsec.ktict.co.kr,cctv.its.go.kr,openapi.its.go.kr
