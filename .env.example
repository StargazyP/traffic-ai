# 이 파일을 복사: cp .env.example .env  후 URL만 채우세요.
# 앱은 프로젝트 루트의 .env 를 자동으로 읽습니다.

# ITS OpenAPI (CCTV 목록·cctvurl). 공개 저장소에는 실제 키를 올리지 마세요.
# CCTV_URL*_ 이 모두 비어 있을 때만 ITS 자동 매칭을 시도합니다(이 경우 ITS_API_KEY 필수).
# ITS_API_KEY=발급받은_키
# ITS_AUTOFETCH_DISABLED=0
# ITS_AUTOFETCH_DISABLED=1  → get_cctv_list·자동 ITS 조회 차단(CCTV_URL 만 사용)
# 한도 보호(대시보드 /rotation/status 1초 폴링 대비):
# ROTATION_SITES_CACHE_TTL_SEC=3600
# ROTATION_SITES_ERROR_TTL_SEC=300
# ROTATION_SITES_PERM_ERROR_TTL_SEC=3600
# get_cctv_list() 공통 TTL(초) — 로테이션 매칭·ITS 상태 검사가 동일 bbox 재사용
# ITS_CCTV_LIST_CACHE_TTL_SEC=300
# .env 에 CCTV_URL 이 있을 때 refresh 가 ITS 를 건너뜀(기본 on). 강제: POST ...?force_its=true
# ITS_REFRESH_SKIP_WHEN_ENV_URLS=1
# ROTATION_BOOT_RETRY_INTERVAL_SEC=60
# ROTATION_BOOT_RETRY_MAX=10
# 401 Unauthorized 가 나오면 키 문제 외에 "사용처(사이트)"와 호스트(https·도메인) 불일치도 의심하세요—마이페이지와 동일하게 ITS_REGISTERED_SITE_URL 설정.
# ITS_HTTP_USER_AGENT=Mozilla/5.0 ... (클라이언트 차단 시에만)
# 포털에 등록한 URL과 반드시 일치(https 권장)
# ITS_REGISTERED_SITE_URL=https://stargazyp.com

# 테스트: 한 개 m3u8만 있으면 아래 한 줄만 넣어도 지점 이름으로 로테이션됩니다.
# ITS 한도 초과(4001) 시 임시 fallback 으로도 사용 가능합니다.
# CCTV_URL=https://openapi.its.go.kr/.../stream.m3u8
#
# ITS 한도 회복 후 지점별 URL 갱신:
#   docker exec traffic-ai-app python3 scripts/refresh_rotation_sites_cache.py
#   또는 POST /rotation/refresh-sites-cache?force_its=true  (CCTV_URL 있어도 ITS 강제, 한도 주의)
# 성공 시 data/rotation_sites_cache.json 에 저장되며, 이후 ITS 한도 초과 시에도 디스크 캐시를 사용합니다.
#
# ITS_API_KEY 도 없고 아래 CCTV URL 도 없으면 로테이션이 시작되지 않습니다(WebSocket 만 연결됨).

# 운영: 지점별로 다른 스트림이면 각각 지정 (비어 있으면 CCTV_URL 로 대체됨)
# CCTV_URL_SUWON_SINGAL_IC=
# CCTV_URL_PANGYO_JCT=
# CCTV_URL_SEOUL_TG=
# CCTV_URL_YONGIN_IC=
# CCTV_URL_SINGAL_JCT=
# CCTV_URL_SEOPYEONGTAEK_JCT=
# CCTV_URL_BIBONG_IC=
# CCTV_URL_MAESONG_IC=
# CCTV_URL_JANGHANG_IC=
# CCTV_URL_JAYURO_JCT=
# CCTV_URL_ILSAN_IC=
# CCTV_URL_YANGJU_IC=
# CCTV_URL_UIJEONGBU_IC=
# CCTV_URL_EAST_UIJEONGBU_IC_NORTH=
# CCTV_URL_NAMGURI_IC=
# CCTV_URL_GURI_IC=
# CCTV_URL_JUNGNANG_IC_BRIDGE=
# CCTV_URL_SINWOL_IC=
# CCTV_URL_GIMPO_IC=
# CCTV_URL_SEOUN_JCT=
# CCTV_URL_TOPYEONG_IC=
# CCTV_URL_SEOHANAM_IC=
# CCTV_URL_SANGIL_IC=
# CCTV_URL_SIHEUNG_IC=
# CCTV_URL_ANHYEON_JCT=

CCTV_ROTATION_SEC=30

# 부팅 직후 ITS/네트워크 지연으로 로테이션 지점이 비었을 때 자동 재시도(초), 120회까지(0이면 무제한)
# ROTATION_BOOT_RETRY_INTERVAL_SEC=15
# ROTATION_BOOT_RETRY_MAX=120

# MySQL (docker-compose 기본값과 맞춤)
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=traffic

# 가상선 세로 위치 = 프레임 높이 × 이 값 (0.05~0.95로 클램프)
LINE_Y_RATIO=0.6

# 로테이션 YOLO track 신뢰도 하한 (낮출수록 검출↑, 오검출↑)
YOLO_TRACK_CONF=0.25

# 하단 CCTV 미리보기 HLS 프록시(브라우저 403 방지). 필요 시 Referer/Origin 조정.
# HLS_PROXY_REFERER=https://openapi.its.go.kr/
# HLS_PROXY_ORIGIN=https://openapi.its.go.kr
# HLS_PROXY_ALLOWED_HOSTS=cctvsec.ktict.co.kr,cctv.its.go.kr,openapi.its.go.kr
